{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=EnterpriseApp;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "EnterpriseApp",
    "Audience": "EnterpriseApp.Clients",
    "SigningKey": "__RESOLVED_FROM_KEY_VAULT_AT_RUNTIME__"
  },
  "KeyVault": {
    "Uri": "https://your-keyvault.vault.azure.net/"
  },
  "RateLimit": {
    "RequestsPerWindow": 100,
    "WindowSeconds": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "https://your-frontend.azurewebsites.net"
    ]
  },
  "AllowedHosts": "*"
}
